# Copy this file to .env and update paths for your machine
# .env is gitignored and should NOT be committed

# ============================================================================
# REQUIRED: Path to your active project repository
# ============================================================================
# Each project has its own Git repo containing:
#   - experiments.csv (experiment metadata for this project)
#   - analysis_parameters.csv (processing settings per experiment)
#   - run_analysis.py (optional batch script)
#
# Example:
PROJECT_REPO=/path/to/your-project-repo

# ============================================================================
# OPTIONAL: Override base path for raw experimental data
# ============================================================================
# By default, data is expected in: experiment_analysis/data/downloaded_data/
# Uncomment and modify if your data lives elsewhere:
#
# BASE_FILE_PATH=/path/to/your/experimental/data
